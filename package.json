{
  "name": "shadowalker",
  "displayName": "影みち",
  "version": "0.3.0",
  "description": "東京の暑い日に、すこしでも日陰の多い徒歩ルートを提案するWebアプリ",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract:plateau": "tsx scripts/extract-plateau.ts",
    "extract:trees": "tsx scripts/extract-trees.ts"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "leaflet": "^1.9.4",
    "proj4": "^2.11.0",
    "rbush": "^4.0.1"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.14.0",
    "@types/proj4": "^2.5.5",
    "@types/rbush": "^4.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
